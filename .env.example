# ─────────────────────────────────────────────────────────────────────────
# Required — the API exits at boot if any of these are missing.
# ─────────────────────────────────────────────────────────────────────────

# SQLite database file. Relative paths resolve from packages/api (where the API
# process runs in local dev), so this points at <repo>/data/app.db.
# docker-compose overrides this to /data/app.db (the mounted volume).
DATABASE_PATH=../../data/app.db

# Service bearer token — programmatic/CI access to the API. Generate with:
# openssl rand -hex 32. TrueNote's web app uses per-user login (Mode C, below),
# NOT this token; it remains for scripts/CI and the reference feature.
AUTH_TOKEN=replace-me-openssl-rand-hex-32

NODE_ENV=development

# ─────────────────────────────────────────────────────────────────────────
# Build-time (frontend) — baked into the bundle by Vite. Must be VITE_-prefixed.
# ─────────────────────────────────────────────────────────────────────────

# Where the SPA calls the API. Leave EMPTY for same-origin (the default; in dev
# Vite proxies /api to the API, so empty is correct there too).
# Only set a full origin for true split-origin serving — which also needs CORS on
# the API and a widened CSP connect-src (GOTCHAS G13).
# Never set this to "/api" — Eden Treaty parses bare paths as hostnames (GOTCHAS G5).
VITE_API_URL=

# (Legacy) Mode B bearer for the SPA — UNUSED by TrueNote, which authenticates
# via the Mode C session cookie. Left blank; safe to ignore.
VITE_AUTH_TOKEN=

# Display name: browser tab title + the label in the sidebar/topbar.
# scripts/init-project.sh sets this from its argument. Quoted so a value with
# spaces stays a single token (and `source .env` in a shell won't choke).
VITE_APP_NAME="App"

# ─────────────────────────────────────────────────────────────────────────
# Optional
# ─────────────────────────────────────────────────────────────────────────

# Expose Swagger UI at /docs. Default false (matches the safe default everywhere).
# Flip to true locally if you want /docs while developing.
ENABLE_SWAGGER=false

# pino log level: trace|debug|info|warn|error. Default info.
LOG_LEVEL=info

# PORT defaults to 3000 (the single prod port). Local dev runs the API on 4000
# and Vite on 3000 (Vite proxies /api -> 4000), so you don't set PORT here.

# ─────────────────────────────────────────────────────────────────────────
# TrueNote — wiki file store, auth, and LLM (all optional; sane defaults)
# ─────────────────────────────────────────────────────────────────────────

# Where the wiki's .md files live (the source of truth). Relative paths resolve
# from packages/api in dev. docker-compose should mount this as a volume.
DOCS_DIR=../../data/wiki

# Commit doc changes to git inside DOCS_DIR for history/undo ('on' | 'off').
# Best-effort: a failed commit never blocks a save.
GIT_VERSIONING=on

# Auth provider. 'dev' = passwordless pick-a-user for LOCAL DEV ONLY (refuses to
# boot under NODE_ENV=production). 'entra' = Microsoft Entra OIDC (production).
AUTH_MODE=dev
# Session lifetime (hours).
SESSION_TTL_HOURS=720
# Bootstrap admins: comma-separated emails promoted to 'admin' on login (maps to
# Entra groups later). Admins manage providers + departments and see all wikis.
ADMIN_EMAILS=

# LLM for the Assistant. 'anthropic' (Claude) or 'openai' (any OpenAI-compatible
# endpoint, including local Ollama via LLM_BASE_URL=http://localhost:11434/v1).
LLM_PROVIDER=anthropic
LLM_MODEL=claude-sonnet-4-6
# LLM_BASE_URL=
# Provider key for whichever provider you use (leave the other blank):
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=

# Scheduled maintenance agent. Master kill-switch for the background timer
# ('on' | 'off'); per-run behavior (enable, interval, checks) is admin config in
# Settings -> Maintenance. Off in tests automatically.
MAINTENANCE_SCHEDULER=on
