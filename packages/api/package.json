{
  "name": "@app/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/app.ts",
  "exports": {
    ".": {
      "types": "./src/app.ts",
      "bun": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "scripts": {
    "dev": "PORT=4000 bun --env-file=../../.env --watch src/index.ts",
    "start": "bun src/index.ts",
    "test": "bun test",
    "type-check": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "bun --env-file=../../.env src/db/migrate.ts",
    "db:seed": "bun --env-file=../../.env src/db/seed.ts",
    "db:studio": "bun --env-file=../../.env drizzle-kit studio"
  },
  "dependencies": {
    "@elysiajs/eden": "^1.4.9",
    "@elysiajs/static": "^1.4.10",
    "@elysiajs/swagger": "^1.3.1",
    "drizzle-orm": "^0.45.2",
    "elysia": "^1.4.28",
    "pino": "^10.3.1"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "drizzle-kit": "^0.31.10",
    "pino-pretty": "^13.1.3"
  }
}
